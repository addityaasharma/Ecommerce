generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum VendorWalletTxnType {
  credit
  debit

  @@map("vendor_wallet_txn_type")
}

enum VendorWalletTxnSource {
  order_earning
  payout_withdrawal
  refund_reversal
  adjustment

  @@map("vendor_wallet_txn_source")
}

enum VendorPayoutStatus {
  pending
  approved
  rejected

  @@map("vendor_payout_status")
}

enum OrderStatus {
  pending
  in_transit @map("in-transit")
  confirmed
  cancelled

  @@map("order_status")
}

enum AffiliateStatus {
  pending
  approved
  rejected

  @@map("affiliate_status")
}

model Admin {
  id             Int      @id @default(autoincrement())
  username       String   @unique @db.VarChar(255)
  password       String   @db.VarChar(255)
  profilePicture String?  @map("profile_picture") @db.VarChar(255)
  phoneNumber    String?  @map("phone_number") @db.VarChar(20)
  bio            String?  @db.Text
  role           String   @default("admin") @db.VarChar(50)
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @default(now()) @updatedAt @map("updated_at")
  vendorProfile  Vendor?

  @@map("admin")
}

model Vendor {
  id                Int            @id @default(autoincrement())
  adminId           Int            @unique @map("admin_id")
  storeName         String         @map("store_name") @db.VarChar(255)
  storeDescription  String?        @map("store_description") @db.Text
  gstNumber         String?        @map("gst_number") @db.VarChar(255)
  upiId             String?        @map("upi_id") @db.VarChar(255)
  bankAccountNumber String?        @map("bank_account_number") @db.VarChar(255)
  bankIfsc          String?        @map("bank_ifsc") @db.VarChar(20)
  bankAccountHolder String?        @map("bank_account_holder") @db.VarChar(255)
  commissionRate    Float          @default(10.0) @map("commission_rate")
  approvalStatus    String         @default("pending") @map("approval_status") @db.VarChar(20)
  isActive          Boolean?       @default(true) @map("is_active")
  createdAt         DateTime       @default(now()) @map("created_at")
  updatedAt         DateTime       @default(now()) @updatedAt @map("updated_at")
  admin             Admin          @relation(fields: [adminId], references: [id], onDelete: Cascade)
  products          Products[]
  payoutRequests    VendorPayout[]
  wallet            VendorWallet?

  @@map("vendor")
}

model VendorWallet {
  id             Int                       @id @default(autoincrement())
  vendorId       Int                       @unique @map("vendor_id")
  balance        Float                     @default(0.0) // withdrawable right now
  totalEarned    Float                     @default(0.0) @map("total_earned") // lifetime credits
  totalWithdrawn Float                     @default(0.0) @map("total_withdrawn") // lifetime approved payouts
  createdAt      DateTime                  @default(now()) @map("created_at")
  updatedAt      DateTime                  @default(now()) @updatedAt @map("updated_at")
  vendor         Vendor                    @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  transactions   VendorWalletTransaction[]

  @@map("vendor_wallet")
}

model VendorWalletTransaction {
  id           Int                   @id @default(autoincrement())
  walletId     Int                   @map("wallet_id")
  type         VendorWalletTxnType
  source       VendorWalletTxnSource
  amount       Float
  balanceAfter Float                 @map("balance_after")
  referenceId  Int?                  @map("reference_id") // order_id / payout_id depending on source
  note         String?               @db.VarChar(255)
  createdAt    DateTime              @default(now()) @map("created_at")

  wallet       VendorWallet  @relation(fields: [walletId], references: [id], onDelete: Cascade)
  vendorPayout VendorPayout?

  @@map("vendor_wallet_transaction")
}

model VendorPayout {
  id                  Int                      @id @default(autoincrement())
  vendorId            Int                      @map("vendor_id")
  amount              Float
  status              VendorPayoutStatus       @default(pending)
  paymentScreenshot   String?                  @map("payment_screenshot") @db.VarChar(255)
  note                String?                  @db.VarChar(255)
  walletTransactionId Int?                     @unique @map("wallet_transaction_id")
  createdAt           DateTime                 @default(now()) @map("created_at")
  updatedAt           DateTime                 @default(now()) @updatedAt @map("updated_at")
  vendor              Vendor                   @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  walletTransaction   VendorWalletTransaction? @relation(fields: [walletTransactionId], references: [id])

  @@map("vendor_payout")
}

model Store {
  id           Int      @id @default(autoincrement())
  name         String   @unique @db.VarChar(255)
  description  String?  @db.Text
  logo         String?  @db.VarChar(255)
  address      String?  @db.VarChar(255)
  gstNumber    String?  @unique @map("gst_number") @db.VarChar(255)
  supportEmail String?  @map("support_email") @db.VarChar(255)
  supportPhone String?  @map("support_phone") @db.VarChar(20)
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @default(now()) @updatedAt @map("updated_at")

  @@map("store")
}

model Notification {
  id                  Int      @id @default(autoincrement())
  orderPlaced         Boolean? @default(false) @map("order_placed")
  paymentFailed       Boolean? @default(false) @map("payment_failed")
  lowStock            Boolean? @default(false) @map("low_stock")
  newUserRegistration Boolean? @default(false) @map("new_user_registration")
  newProductReview    Boolean? @default(false) @map("new_product_review")
  emailNotifications  Boolean? @default(false) @map("email_notifications")
  smsNotifications    Boolean? @default(false) @map("sms_notifications")
  pushNotifications   Boolean? @default(false) @map("push_notifications")
  createdAt           DateTime @default(now()) @map("created_at")
  updatedAt           DateTime @default(now()) @updatedAt @map("updated_at")

  @@map("notification")
}

model PaymentSettings {
  id             Int      @id @default(autoincrement())
  paymentGateway String   @map("payment_gateway") @db.VarChar(255)
  apiKey         String   @map("api_key") @db.VarChar(255)
  apiSecret      String   @map("api_secret") @db.VarChar(255)
  upiId          String?  @map("upi_id") @db.VarChar(255)
  cod            Boolean? @default(false)
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @default(now()) @updatedAt @map("updated_at")

  @@map("payment_settings")
}

model Category {
  id          Int        @id @default(autoincrement())
  name        String     @unique @db.VarChar(255)
  description String?    @db.Text
  slug        String     @unique @db.VarChar(255)
  icon        String?    @db.VarChar(255)
  color       String?    @db.VarChar(20)
  createdAt   DateTime   @default(now()) @map("created_at")
  updatedAt   DateTime   @default(now()) @updatedAt @map("updated_at")
  products    Products[]

  @@map("category")
}

model Products {
  id                 Int                  @id @default(autoincrement())
  categoryId         Int?                 @map("category_id")
  vendorId           Int?                 @map("vendor_id")
  name               String               @unique @db.VarChar(255)
  description        String?              @db.Text
  productImage       String               @map("product_image") @db.VarChar(255)
  productImages      Json?                @map("product_images")
  sizes              Json?
  colors             Json?
  price              Float
  compareAtPrice     Float?               @map("compare_at_price")
  stock              Int
  unitPrice          Float?               @map("unit_price")
  chargeTax          Boolean?             @default(false) @map("charge_tax")
  taxRate            Float?               @map("tax_rate")
  costPrice          Float?               @map("cost_price")
  sku                String               @unique @db.VarChar(255)
  barcode            String?              @unique @db.VarChar(255)
  countryOfOrigin    String?              @map("country_of_origin") @db.VarChar(255)
  weight             Float?
  weightUnit         String?              @map("weight_unit") @db.VarChar(20)
  commission         Int?                 @default(2)
  productType        String?              @map("product_type") @db.VarChar(255)
  sellWhenOutOfStock Boolean?             @default(false) @map("sell_when_out_of_stock")
  quantity           Int
  status             String               @default("active") @db.VarChar(50)
  createdAt          DateTime             @default(now()) @map("created_at")
  updatedAt          DateTime             @default(now()) @updatedAt @map("updated_at")
  category           Category?            @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  vendor             Vendor?              @relation(fields: [vendorId], references: [id], onDelete: SetNull)
  productReviews     ProductReview[]
  collectionProducts CollectionProducts[]
  orderlist          OrderList[]
  orderedItems       OrderedItems[]

  @@map("products")
}

model ProductReview {
  id        Int      @id @default(autoincrement())
  productId Int      @map("product_id")
  userId    Int      @map("user_id")
  rating    Int
  review    String?  @db.Text
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at")
  product   Products @relation(fields: [productId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("product_review")
}

model Banner {
  id          Int      @id @default(autoincrement())
  title       String   @db.VarChar(255)
  description String?  @db.Text
  linkName    String?  @map("link_name") @db.VarChar(255)
  link        String?  @db.VarChar(255)
  code        String?  @db.VarChar(255)
  status      String   @default("active") @db.VarChar(50)
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @default(now()) @updatedAt @map("updated_at")

  @@map("banner")
}

model Collection {
  id                 Int                  @id @default(autoincrement())
  name               String               @unique @db.VarChar(255)
  description        String?              @db.VarChar(255)
  image              String?              @db.VarChar(255)
  collectionProducts CollectionProducts[]

  @@map("collection")
}

model CollectionProducts {
  id           Int        @id @default(autoincrement())
  productId    Int        @map("product_id")
  collectionId Int        @map("collection_id")
  collection   Collection @relation(fields: [collectionId], references: [id], onDelete: Cascade)
  product      Products   @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([productId, collectionId], name: "uq_product_collection")
  @@map("collection_products")
}

model User {
  id                  Int                  @id @default(autoincrement())
  username            String               @unique @db.VarChar(255)
  email               String               @unique @db.VarChar(255)
  password            String               @db.VarChar(255)
  googleId            String?              @unique @map("google_id") @db.VarChar(128)
  profilePicture      String?              @map("profile_picture") @db.VarChar(255)
  phoneNumber         String?              @map("phone_number") @db.VarChar(20)
  bio                 String?              @db.Text
  role                String               @default("customer") @db.VarChar(50)
  isAffiliate         Boolean?             @default(false) @map("is_affiliate")
  affiliateId         String?              @map("affiliate_id") @db.VarChar(255)
  createdAt           DateTime             @default(now()) @map("created_at")
  updatedAt           DateTime             @default(now()) @updatedAt @map("updated_at")
  addresses           Address[]
  wishlist            WishList[]
  cart                Cart[]
  orders              Orders[]
  payments            Payment[]
  refunds             Refund[]
  affiliate           AffiliateDashboard?
  productReviews      ProductReview[]
  supportConversation SupportConversation?

  @@map("user")
}

model AffiliateDashboard {
  id              Int             @id @default(autoincrement())
  userId          Int             @unique @map("user_id")
  totalOrders     Float?          @default(0.0) @map("total_orders")
  totalRevenue    Float           @default(0.0) @map("total_revenue")
  totalWithdrawal Float           @default(0.0) @map("total_withdrawal")
  upiId           String          @default("") @map("upi_id") @db.VarChar(255)
  createdAt       DateTime        @default(now()) @map("created_at")
  updatedAt       DateTime        @default(now()) @updatedAt @map("updated_at")
  user            User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  orderlist       OrderList[]
  withdrawals     Withdrawal[]
  notifications   Notifications[]

  @@map("affiliate_dashboard")
}

model OrderList {
  id          Int                @id @default(autoincrement())
  affiliateId Int                @map("affiliate_id")
  productId   Int                @map("product_id")
  orderId     Int?               @map("order_id")
  commission  Float              @default(0.0)
  revenue     Float              @default(0.0)
  status      OrderStatus        @default(pending)
  createdAt   DateTime           @default(now()) @map("created_at")
  updatedAt   DateTime           @default(now()) @updatedAt @map("updated_at")
  affiliate   AffiliateDashboard @relation(fields: [affiliateId], references: [id], onDelete: Cascade)
  products    Products           @relation(fields: [productId], references: [id], onDelete: Cascade)
  orders      Orders?            @relation(fields: [orderId], references: [id])

  @@map("ordered_list")
}

model Withdrawal {
  id          Int                @id @default(autoincrement())
  affiliateId Int                @map("affiliate_id")
  amount      Float
  payslip     String?            @db.VarChar(255)
  status      AffiliateStatus    @default(pending)
  note        String?            @db.VarChar(255)
  createdAt   DateTime           @default(now()) @map("created_at")
  updatedAt   DateTime           @default(now()) @updatedAt @map("updated_at")
  affiliate   AffiliateDashboard @relation(fields: [affiliateId], references: [id], onDelete: Cascade)

  @@map("withdrawal")
}

model Notifications {
  id          Int                @id @default(autoincrement())
  affiliateId Int                @map("affiliate_id")
  message     String             @db.VarChar(255)
  createdAt   DateTime           @default(now()) @map("created_at")
  updatedAt   DateTime           @default(now()) @updatedAt @map("updated_at")
  affiliate   AffiliateDashboard @relation(fields: [affiliateId], references: [id], onDelete: Cascade)

  @@map("notifications")
}

model Address {
  id         Int      @id @default(autoincrement())
  userId     Int      @map("user_id")
  street     String   @db.VarChar(255)
  city       String   @db.VarChar(255)
  state      String   @db.VarChar(255)
  postalCode String   @map("postal_code") @db.VarChar(20)
  country    String   @db.VarChar(255)
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @default(now()) @updatedAt @map("updated_at")
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  orders     Orders[]

  @@map("address")
}

model WishList {
  id        Int      @id @default(autoincrement())
  userId    Int      @map("user_id")
  productId Int      @map("product_id")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("wishlist")
}

model Cart {
  id        Int      @id @default(autoincrement())
  userId    Int      @map("user_id")
  productId Int      @map("product_id")
  quantity  Int
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("cart")
}

model Orders {
  id                Int            @id @default(autoincrement())
  userId            Int            @map("user_id")
  orderId           String         @unique @map("order_id") @db.VarChar(255)
  addressId         Int?           @map("address_id")
  shippingAddress   Json           @map("shipping_address")
  subtotal          Float
  taxAmount         Float?         @default(0) @map("tax_amount")
  razorpayOrderId   String?        @map("razorpay_order_id") @db.VarChar(255)
  discount          Float?         @default(0)
  shippingCharges   Float          @default(0) @map("shipping_charges")
  totalPrice        Float          @map("total_price")
  orderSource       String         @default("cart") @map("order_source") @db.VarChar(50)
  affiliateId       String?        @map("affiliate_id") @db.VarChar(100)
  status            String         @default("pending") @db.VarChar(50)
  paymentMethod     String         @map("payment_method") @db.VarChar(50)
  paymentStatus     String         @default("unpaid") @map("payment_status") @db.VarChar(50)
  shiprocketOrderId String?        @map("shiprocket_order_id") @db.VarChar(100)
  shipmentId        String?        @map("shipment_id") @db.VarChar(100)
  trackingUrl       String?        @map("tracking_url") @db.VarChar(500)
  awbCode           String?        @map("awb_code") @db.VarChar(100)
  createdAt         DateTime       @default(now()) @map("created_at")
  updatedAt         DateTime       @default(now()) @updatedAt @map("updated_at")
  user              User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  address           Address?       @relation(fields: [addressId], references: [id], onDelete: SetNull)
  orderedItems      OrderedItems[]
  payment           Payment[]
  refund            Refund[]
  orderList         OrderList[]

  @@map("orders")
}

model OrderedItems {
  id           Int      @id @default(autoincrement())
  orderId      Int      @map("order_id")
  productId    Int?     @map("product_id")
  productName  String   @map("product_name") @db.VarChar(255)
  productSku   String   @map("product_sku") @db.VarChar(255)
  productImage String?  @map("product_image") @db.VarChar(255)
  quantity     Int
  unitPrice    Float    @map("unit_price")
  taxRate      Float?   @map("tax_rate")
  taxAmount    Float?   @map("tax_amount")
  discount     Float?   @default(0)
  totalPrice   Float    @map("total_price")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @default(now()) @updatedAt @map("updated_at")

  orders  Orders    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product Products? @relation(fields: [productId], references: [id], onDelete: SetNull)

  @@map("ordered_items")
}

model Payment {
  id                Int       @id @default(autoincrement())
  orderId           Int       @map("order_id")
  userId            Int       @map("user_id")
  paymentMethod     String    @map("payment_method") @db.VarChar(50)
  amount            Float
  currency          String    @default("INR") @db.VarChar(10)
  status            String    @default("pending") @db.VarChar(50)
  razorpayOrderId   String?   @map("razorpay_order_id") @db.VarChar(255)
  razorpayPaymentId String?   @map("razorpay_payment_id") @db.VarChar(255)
  razorpaySignature String?   @map("razorpay_signature") @db.VarChar(255)
  paymentResponse   Json?     @map("payment_response")
  refundId          String?   @map("refund_id") @db.VarChar(255)
  refundAmount      Float?    @map("refund_amount")
  refundStatus      String?   @map("refund_status") @db.VarChar(50)
  // pending -> processed -> failed
  refundReason      String?   @map("refund_reason") @db.VarChar(255)
  failureReason     String?   @map("failure_reason") @db.VarChar(255)
  paidAt            DateTime? @map("paid_at")
  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @default(now()) @updatedAt @map("updated_at")
  order             Orders    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  user              User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  refund            Refund[]

  @@map("payment")
}

model Refund {
  id               Int       @id @default(autoincrement())
  orderId          Int       @map("order_id")
  userId           Int       @map("user_id")
  paymentId        Int       @map("payment_id")
  reason           String    @db.VarChar(100)
  description      String?   @db.Text // user's detailed explanation
  refundAmount     Float     @map("refund_amount")
  refundType       String    @map("refund_type") @db.VarChar(20) // "full" or "partial"
  itemIds          Json?     @map("item_ids") // which items in partial refund
  status           String    @default("pending") @db.VarChar(50)
  razorpayRefundId String?   @map("razorpay_refund_id") @db.VarChar(255)
  bankReference    String?   @map("bank_reference") @db.VarChar(255) // for COD refunds
  rejectionReason  String?   @map("rejection_reason") @db.Text
  processedAt      DateTime? @map("processed_at")
  createdAt        DateTime  @default(now()) @map("created_at")
  pickupAgentId    Int?      @map("pickup_agent_id")
  pickedUpAt       DateTime? @map("picked_up_at")
  updatedAt        DateTime  @default(now()) @updatedAt @map("updated_at")
  order            Orders    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  user             User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  payment          Payment   @relation(fields: [paymentId], references: [id], onDelete: Cascade)
  pickupAgent      Agent?    @relation(fields: [pickupAgentId], references: [id], onDelete: SetNull)

  @@map("refund")
}

model Agent {
  id          Int      @id @default(autoincrement())
  name        String   @db.VarChar(255)
  phoneNumber String   @map("phone_number") @db.VarChar(255)
  password    String   @db.VarChar(255)
  agentId     String   @map("agent_id") @db.VarChar(255)
  refunds     Refund[]

  @@map("agent")
}

model SupportConversation {
  id            Int              @id @default(autoincrement())
  userId        Int              @unique @map("user_id")
  status        String           @default("open") @db.VarChar(20) // open / closed
  lastMessage   String?          @map("last_message") @db.VarChar(255)
  lastMessageAt DateTime?        @default(now()) @map("last_message_at")
  unreadByAdmin Int              @default(0) @map("unread_by_admin")
  unreadByUser  Int              @default(0) @map("unread_by_user")
  createdAt     DateTime         @default(now()) @map("created_at")
  updatedAt     DateTime         @default(now()) @updatedAt @map("updated_at")
  user          User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages      SupportMessage[]

  @@map("support_conversation")
}

model SupportMessage {
  id             Int                 @id @default(autoincrement())
  conversationId Int                 @map("conversation_id")
  senderType     String              @map("sender_type") @db.VarChar(10) // "user" or "admin"
  senderId       Int                 @map("sender_id")
  message        String?             @db.Text
  attachmentUrl  String?             @map("attachment_url") @db.VarChar(500)
  attachmentType String?             @map("attachment_type") @db.VarChar(20) // "image" or "file"
  isRead         Boolean             @default(false) @map("is_read")
  createdAt      DateTime            @default(now()) @map("created_at")
  conversation   SupportConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@map("support_message")
}
